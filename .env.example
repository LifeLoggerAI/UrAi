# URAI app environment example
# Copy to .env.local for local development. Do not commit secrets.
# Placeholder values only. Never paste real secrets into this file.

NEXT_PUBLIC_APP_NAME=URAI Genesis
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3014
NEXT_PUBLIC_URAI_APP_URL=https://urai.app

# Firebase public web config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin/server-only config
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI provider config
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Admin/founder access
URAI_ADMIN_EMAILS=
# Use NEXT_PUBLIC_URAI_FOUNDER_EMAILS only if intentionally safe for the client bundle.
NEXT_PUBLIC_URAI_FOUNDER_EMAILS=

# Launch controls
NEXT_PUBLIC_URAI_PUBLIC_DEMO_ENABLED=true
NEXT_PUBLIC_URAI_WAITLIST_ENABLED=true
NEXT_PUBLIC_URAI_LAUNCH_STATUS=public_demo

# Optional analytics/monitoring
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=

# Optional messaging providers, only if wired
RESEND_API_KEY=
SMS_PROVIDER_ACCOUNT_SID=
SMS_PROVIDER_AUTH_TOKEN=
SMS_PROVIDER_FROM_NUMBER=

# Cross-repo integration endpoints
NEXT_PUBLIC_URAI_JOBS_URL=
NEXT_PUBLIC_URAI_CONTENT_URL=
NEXT_PUBLIC_ASSET_FACTORY_URL=
NEXT_PUBLIC_URAI_SPATIAL_URL=
NEXT_PUBLIC_URAI_STUDIO_URL=
NEXT_PUBLIC_URAI_B2B_URL=

# Default safe behavior
URAI_DEMO_MODE=true
URAI_REQUIRE_PROVIDER_SECRETS=false
URAI_WAITLIST_DRY_RUN=1
