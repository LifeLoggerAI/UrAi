rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // URAI export/media baseline:
    // - No public reads by default.
    // - Users may only access their own export/media paths.
    // - Add stricter file size/content-type checks before production uploads.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
