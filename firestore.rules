rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function ownsExistingDoc() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function ownsIncomingDoc() {
      return (
        isSignedIn() &&
        request.resource.data.ownerUid is string &&
        request.resource.data.ownerUid == request.auth.uid
      );
    }

    function canReadOwnerDoc() {
      return ownsExistingDoc() || isAdmin();
    }

    function canCreateOwnerDoc() {
      return ownsIncomingDoc() || isAdmin();
    }

    function canUpdateOwnerDoc() {
      return isAdmin() || (ownsExistingDoc() && ownsIncomingDoc() &&
        resource.data.ownerUid == request.resource.data.ownerUid);
    }

    function canDeleteOwnerDoc() {
      return ownsExistingDoc() || isAdmin();
    }

    function canReadPublicDoc() {
      return true;
    }

    function canWritePublicDoc() {
      return isAdmin();
    }

    function canAccessServerOnlyDoc() {
      return isAdmin();
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }

    match /adminUsers/{id} { allow read, write: if canAccessServerOnlyDoc(); }
    match /adminAuditLogs/{id} { allow read, write: if canAccessServerOnlyDoc(); }
    match /auditLogs/{id} { allow read, write: if canAccessServerOnlyDoc(); }
    match /creatorSubmissions/{id} { allow read, write: if canAccessServerOnlyDoc(); }
    match /incidents/{id} { allow read, write: if canAccessServerOnlyDoc(); }
    match /waitlistEntries/{id} { allow read, write: if canAccessServerOnlyDoc(); }
    match /contactMessages/{id} { allow read, write: if canAccessServerOnlyDoc(); }

    match /marketplaceItems/{id} { allow read: if canReadPublicDoc(); allow create, update, delete: if canWritePublicDoc(); }
    match /jobs/{id} { allow read: if canReadPublicDoc(); allow create, update, delete: if canWritePublicDoc(); }
    match /featureFlags/{id} { allow read: if canReadPublicDoc(); allow create, update, delete: if canWritePublicDoc(); }
    match /systemStatus/{id} { allow read: if canReadPublicDoc(); allow create, update, delete: if canWritePublicDoc(); }

    match /profiles/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /consents/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /narratorMemory/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /memoryShards/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /insights/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /journeys/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /journeyChapters/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /stars/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /moodWeather/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /emotionalForecasts/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /weeklyRecaps/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /storyProjects/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /storyAssets/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /marketplacePurchases/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /referrals/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /jobApplications/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /telemetryEvents/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /safetyEvents/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /dataExportRequests/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /accountDeletionRequests/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /eventEnrichments/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /lifeMapEvents/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /constellations/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /scrolls/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /storyScripts/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /relationships/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /socialGraph/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /obscuraSignals/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /mentalLoadScores/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /councilSessions/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /narratorMessages/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /entitlements/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /transactions/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /dataRequests/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }

    match /dreams/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /rituals/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /timelineEvents/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /personaEvolutions/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /soulThreads/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /socialArchetypes/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /weeklyScrolls/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /weeklyReflections/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /moods/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /moodForecasts/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /shadowMetrics/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /obscuraPatterns/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /cognitiveStress/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /recoveryBlooms/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /memoryBlooms/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /relationshipConstellations/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /relationshipSignals/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /voiceEvents/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /dreamConstellations/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /badges/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /notifications/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /journalEntries/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /events/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /insightMarket/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /chronoMirrorSnapshots/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /chrono_validation_events/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /ancientSignals/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /companionMessages/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /narratorInsights/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /passiveSignals/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }
    match /symbolicStates/{id} { allow read: if canReadOwnerDoc(); allow create: if canCreateOwnerDoc(); allow update: if canUpdateOwnerDoc(); allow delete: if canDeleteOwnerDoc(); }

    match /waitlistSignups/{id} {
      allow read, write: if false;
    }

    match /feedback/{id} {
      allow read: if false;
      allow create: if
        request.resource.data.keys().hasOnly(["message", "email", "created_at", "source", "user_agent"]) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() <= 2000 &&
        (!request.resource.data.email || request.resource.data.email == null || (request.resource.data.email is string && request.resource.data.email.size() <= 320)) &&
        request.resource.data.created_at is timestamp &&
        (!request.resource.data.source || request.resource.data.source == null || (request.resource.data.source is string && request.resource.data.source.size() <= 500)) &&
        (!request.resource.data.user_agent || request.resource.data.user_agent == null || (request.resource.data.user_agent is string && request.resource.data.user_agent.size() <= 1000));
    }

    match /bug_reports/{id} {
      allow read: if false;
      allow create: if
        request.resource.data.keys().hasOnly(["description", "email", "created_at", "route", "user_agent", "console_log", "local_storage_keys"]) &&
        request.resource.data.description is string &&
        request.resource.data.description.size() <= 4000 &&
        (!request.resource.data.email || request.resource.data.email == null || (request.resource.data.email is string && request.resource.data.email.size() <= 320)) &&
        request.resource.data.created_at is timestamp &&
        (!request.resource.data.route || request.resource.data.route == null || (request.resource.data.route is string && request.resource.data.route.size() <= 500)) &&
        (!request.resource.data.user_agent || request.resource.data.user_agent == null || (request.resource.data.user_agent is string && request.resource.data.user_agent.size() <= 1000)) &&
        (!request.resource.data.console_log || request.resource.data.console_log == null || (request.resource.data.console_log is string && request.resource.data.console_log.size() <= 20000)) &&
        (!request.resource.data.local_storage_keys || request.resource.data.local_storage_keys == null || (request.resource.data.local_storage_keys is string && request.resource.data.local_storage_keys.size() <= 5000));
    }

    match /users/{uid}/settings/{doc} { allow read, write: if request.auth != null && request.auth.uid == uid; }
    match /users/{uid}/tokens/{doc} { allow read, write: if request.auth != null && request.auth.uid == uid; }

    match /{document=**} { allow read, write: if false; }
  }
}
