# Public values (NEXT_PUBLIC_* are sent to the browser)
NEXT_PUBLIC_APP_NAME=UrAi
NEXT_PUBLIC_ENV=prod

# Firebase web app configuration
# Duplicate these keys for each environment (e.g. NEXT_PUBLIC_FIREBASE_*_STAGING) if you need
# separate staging and production projects.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=urai-4dc1d
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Private values (only in .env.local; never commit that file)
OPENAI_API_KEY=

# Local/demo-only admin status header gate.
# Keep this unset or 0 in production. Production admin APIs must use verified auth/session/custom-claim checks.
URAI_ENABLE_HEADER_ADMIN_STATUS=0

# Firebase service account configuration (used server-side only)
# Production hosting for this repo targets project/site urai-4dc1d. Use explicit staging
# credentials only in local/staging-only contexts, never for production deploy evidence.
FIREBASE_PROJECT_ID=urai-4dc1d
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
