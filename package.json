{
  "name": "urai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "node scripts/check-install-disk-space.mjs",
    "install:check": "node scripts/check-install-disk-space.mjs",
    "dev": "next dev -p 3014 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3014",
    "lint": "eslint --ext .ts,.tsx src",
    "test:rules": "jest --config tests/rules/jest.config.cjs",
    "ci": "npm install && npm run doctor && npm run check:v1 && npm run check:tier2-access && npm run seed:demo && npm run check:types && npm run lint && npm run test:unit && npm run test:rules && npm run build",
    "doctor": "node scripts/repo-doctor.mjs",
    "bootstrap:check": "npm run doctor",
    "health": "bash ./scripts/baseline_health_check.sh",
    "clean": "rimraf .next node_modules .turbo",
    "clean:install": "node scripts/clean-install-artifacts.mjs",
    "reinstall": "npm run clean:install && npm install",
    "codemod:dry": "node scripts/replace-demo-user.mjs --dry",
    "codemod:apply": "node scripts/replace-demo-user.mjs",
    "check:v1": "node scripts/check-v1.mjs",
    "check:lockfile": "node scripts/check-lockfile.mjs",
    "check:firestore-contract": "node scripts/check-firestore-contract.mjs",
    "check:public-copy": "node scripts/check-public-copy.mjs",
    "check:firebase": "node scripts/check-firebase-target.mjs",
    "check:firebase:staging": "URAI_EXPECTED_FIREBASE_PROJECT=urai-staging URAI_EXPECTED_FIREBASE_SITE=urai-staging node scripts/check-firebase-target.mjs --config firebase.staging.json",
    "check:clean-tree": "node scripts/check-clean-working-tree.mjs",
    "check:types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "check:home": "node scripts/check-home-lock.mjs",
    "check:ascent": "node scripts/check-ascent-lock.mjs",
    "check:tier2-access": "node scripts/tier-lock/tier2-access-check.mjs",
    "check:tier-freeze": "node scripts/tier-lock/tier-freeze-ledger.mjs",
    "check:tier-freeze:strict": "node scripts/tier-lock/tier-freeze-ledger.mjs --strict",
    "validate": "npm run validate:completion",
    "validate:completion": "node scripts/urai-completion-audit.mjs",
    "preflight": "npm run doctor && npm run check:firebase && npm run check:v1 && npm run check:firestore-contract && npm run check:public-copy && npm run validate:completion && npm run check:types && npm run lint && npm run test:unit && npm run build",
    "launch:p0": "node scripts/p0-launch-gate.mjs",
    "launch:check": "npm run launch:p0",
    "launch:p0:commands": "npm run doctor && node scripts/p0-command-matrix.mjs",
    "release:p1": "node scripts/p1-release-gate.mjs",
    "deploy:evidence": "node scripts/deployment-evidence-check.mjs",
    "live:check": "npm run verify:release:full",
    "seed:demo": "node scripts/seed-demo.mjs",
    "seed:firestore": "node scripts/seed-demo.mjs --firestore",
    "seed:tier2": "node scripts/seed-tier2-access.mjs",
    "seed:tier2:firestore": "node scripts/seed-tier2-access.mjs --firestore",
    "waitlist:export": "node scripts/export-waitlist.mjs",
    "ship:urai": "bash scripts/deploy-urai-firebase.sh",
    "ship:urai:staging": "URAI_DEPLOY_ENV=staging bash scripts/deploy-urai-firebase.sh",
    "ship:urai:prod": "URAI_DEPLOY_ENV=production bash scripts/deploy-urai-firebase.sh",
    "test": "jest",
    "test:unit": "jest tests/unit --passWithNoTests",
    "test:integration": "jest tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/e2e --grep @smoke",
    "test:smoke:production": "playwright test tests/e2e/v1-production-smoke.spec.ts --grep @production-smoke",
    "test:smoke:staging": "PLAYWRIGHT_BASE_URL=https://urai-staging.web.app playwright test tests/e2e --grep @smoke",
    "verify:release": "node scripts/independent-release-verifier.mjs",
    "verify:release:full": "URAI_VERIFIER_RUN_COMMANDS=1 node scripts/independent-release-verifier.mjs",
    "urai:tier1:lock": "node scripts/tier-lock/tier1-launch-lock.mjs",
    "urai:tier2:polish": "node scripts/tier-lock/route-audit.mjs",
    "urai:tier3:audit": "npm run typecheck && npm run build && node scripts/tier-lock/route-audit.mjs && node scripts/tier-lock/console-warning-audit.mjs",
    "urai:tier4:deploy-check": "node scripts/tier-lock/env-readiness-audit.mjs && npm run build",
    "urai:tier5:launch-lock": "npm run urai:tier1:lock && npm run urai:tier3:audit && npm run urai:tier4:deploy-check && node scripts/tier-lock/tier-lock-report.mjs",
    "urai:tier1": "npm run urai:tier1:lock",
    "urai:tier2": "npm run urai:tier2:polish",
    "urai:tier3": "npm run urai:tier3:audit",
    "urai:tier4": "npm run urai:tier4:deploy-check",
    "urai:tier5": "npm run urai:tier5:launch-lock"
  },
  "dependencies": {
    "@react-three/fiber": "^9.0.0",
    "eslint-config-next": "^15.5.2",
    "firebase": "^12.2.1",
    "firebase-admin": "^13.0.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.544.0",
    "next": "^15.5.18",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.2.6",
    "@types/three": "^0.170.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.15",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "20"
  }
}
