{
  "name": "urai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3014 --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --ext .ts,.tsx src || true",
    "test:rules": "jest --config tests/rules/jest.config.cjs",
    "ci": "npm ci && npm run check:types && npm run lint && npm run test:rules && npm run build",
    "health": "bash ./scripts/baseline_health_check.sh",
    "clean": "rimraf .next node_modules .turbo",
    "reinstall": "npm run clean && npm i",
    "codemod:dry": "node scripts/replace-demo-user.mjs --dry",
    "codemod:apply": "node scripts/replace-demo-user.mjs",
    "check:types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "preflight": "npm run check:types && npm run lint && npm run build",
    "seed:demo": "node scripts/seed-demo.mjs",
    "test": "jest",
    "test:unit": "jest tests/unit --passWithNoTests",
    "test:integration": "jest tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/e2e --grep @smoke",
    "verify:release": "node scripts/independent-release-verifier.mjs",
    "verify:release:full": "URAI_VERIFIER_RUN_COMMANDS=1 node scripts/independent-release-verifier.mjs",
    "urai:tier1:lock": "node scripts/tier-lock/tier1-launch-lock.mjs",
    "urai:tier2:polish": "node scripts/tier-lock/route-audit.mjs",
    "urai:tier3:audit": "pnpm typecheck && pnpm build && node scripts/tier-lock/route-audit.mjs && node scripts/tier-lock/console-warning-audit.mjs",
    "urai:tier4:deploy-check": "node scripts/tier-lock/env-readiness-audit.mjs && pnpm build",
    "urai:tier5:launch-lock": "pnpm urai:tier1:lock && pnpm urai:tier3:audit && pnpm urai:tier4:deploy-check && node scripts/tier-lock/tier-lock-report.mjs",
    "urai:tier1": "pnpm urai:tier1:lock",
    "urai:tier2": "pnpm urai:tier2:polish",
    "urai:tier3": "pnpm urai:tier3:audit",
    "urai:tier4": "pnpm urai:tier4:deploy-check",
    "urai:tier5": "pnpm urai:tier5:launch-lock"
  },
  "dependencies": {
    "eslint-config-next": "^15.5.2",
    "firebase": "^12.2.1",
    "firebase-admin": "^13.0.0",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "next": "^15.5.3",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "20"
  }
}
